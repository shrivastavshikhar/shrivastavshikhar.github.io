  author={al.,Shikhar Srivastava et},
  year={2025},
  publisher={U.S. Patent No. 12505232},
  abstract={The invention provides a robust and effective, scalable enterpise grade security solution for facilitating format preserving encryption for, both, data-at-rest and data-in-motion within a Big Data ecosystem. Format preserving encryption (or FPE) keeps the format of the dataset intact and allows easy access to datasets in data lake(s) without concerns of unauthorized downstream access. The solution also provides controls for authorized users to decrypt the original sensitive values from the encrypted ones for re-production of the source data stream based on custom requirements or audit purposes.},
  url={https://ppubs.uspto.gov/basic/}
  
}

